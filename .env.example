# Umgebungsvariablen für die Anwendung
# Kopieren Sie diese Datei zu .env und passen Sie die Werte an

# Flask-Umgebung (development, production, testing)
FLASK_ENV=development

# Secret Key für Session-Verwaltung (ändern Sie in Produktion!)
SECRET_KEY=your-secret-key-change-in-production

# Datenbank-Konfiguration
DATABASE_URL=postgresql://postgres:password@localhost:5432/hotel_db

# Flask Debug Mode
FLASK_DEBUG=1

# Flask App
FLASK_APP=app.py

